@model List<Task01.Models.IndividualRegistration>
@{
    ViewData["Title"] = "تسجيل الأفراد";
}

<h1 class="h3 mb-4">تسجيلات الأفراد (@Model.Count)</h1>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>الاسم</th>
                    <th>البريد</th>
                    <th>الجوال</th>
                    <th>الجنسية</th>
                    <th>جهة العمل</th>
                    <th>المسمى</th>
                    <th>سبب الحضور</th>
                    <th>التاريخ</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="9" class="text-center text-muted py-4">لا توجد تسجيلات بعد.</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.FullName</td>
                    <td dir="ltr">@r.Email</td>
                    <td dir="ltr">@r.Phone</td>
                    <td>@r.Nationality</td>
                    <td>@r.Organization</td>
                    <td>@r.JobTitle</td>
                    <td style="max-width:240px">@r.AttendanceReason</td>
                    <td dir="ltr">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

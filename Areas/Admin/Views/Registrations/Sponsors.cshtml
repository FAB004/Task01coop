@model List<Task01.Models.SponsorRegistration>
@{
    ViewData["Title"] = "الرعاة";
}

<h1 class="h3 mb-4">طلبات الرعاية (@Model.Count)</h1>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>الشركة</th>
                    <th>مسؤول التواصل</th>
                    <th>البريد</th>
                    <th>الجوال</th>
                    <th>نوع الرعاية</th>
                    <th>الرسالة</th>
                    <th>التاريخ</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted py-4">لا توجد طلبات بعد.</td></tr>
            }
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.CompanyName</td>
                    <td>@r.ContactPerson</td>
                    <td dir="ltr">@r.Email</td>
                    <td dir="ltr">@r.Phone</td>
                    <td>@r.SponsorshipType</td>
                    <td style="max-width:240px">@r.Message</td>
                    <td dir="ltr">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@model List<Task01.Models.AgendaItem>
@{
    ViewData["Title"] = "الأجندة";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">الأجندة</h1>
    <a class="btn btn-success" asp-area="Admin" asp-controller="Agenda" asp-action="Create"><i class="bi bi-plus-lg"></i> إضافة بند</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead class="table-light">
                <tr><th>اليوم</th><th>العنوان</th><th>الوقت</th><th>الترتيب</th><th></th></tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5" class="text-center text-muted py-4">لا توجد بنود.</td></tr>
            }
            @foreach (var i in Model)
            {
                <tr>
                    <td>اليوم @i.DayNumber</td>
                    <td>@i.Title</td>
                    <td>@i.Time</td>
                    <td>@i.Order</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-area="Admin" asp-controller="Agenda" asp-action="Edit" asp-route-id="@i.Id">تعديل</a>
                        <form asp-area="Admin" asp-controller="Agenda" asp-action="Delete" asp-route-id="@i.Id" method="post" class="d-inline" onsubmit="return confirm('حذف هذا البند؟');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
